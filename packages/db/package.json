{
  "name": "@super-mcp/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "migrate": "tsx src/migrate.ts",
    "seed": "tsx src/seed.ts",
    "check-integrity": "tsx src/check-integrity.ts",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@super-mcp/shared": "workspace:*",
    "pg": "^8.16.0",
    "dotenv": "^16.5.0"
  },
  "devDependencies": {
    "@types/pg": "^8.15.2"
  }
}
