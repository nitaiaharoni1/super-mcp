DATABASE_URL=postgresql://nitai@localhost:5432/super_mcp
PORT=8787
HOST=0.0.0.0
RAW_ARCHIVE_DIR=./data/raw
LOG_LEVEL=info
# Required for optimize_basket continuations (≥32 bytes). Generate a random value for local/prod.
# Example (tests only): test-only-basket-continuation-secret-ok
BASKET_CONTINUATION_SECRET=
# Immutable MCP/API build identity (CI should inject git SHA). Falls back to "dev".
# SUPER_MCP_BUILD_REVISION=
# GIT_COMMIT_SHA=
# Contract canary: set EXPECTED_BUILD_REVISION to fail on stale deployed builds.
# EXPECTED_BUILD_REVISION=
# SUPER_MCP_REQUIRE_BUILD_REVISION=1
# Basket live canary (Neve Amal defaults): CANARY_BASKET_AUTO_RESUME=1 CANARY_BASKET_STORE_ID=<uuid>
# Free-text location geocoding (Nominatim). Cache keys are HMAC — never store raw addresses.
# GEOCODING_CACHE_SECRET must be ≥32 bytes (required when resolving `location=`).
# GEOCODING_CACHE_SECRET=
# NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org
# NOMINATIM_USER_AGENT=super-mcp-geocode/1.0 (contact: you@example.com)
# NOMINATIM_TIMEOUT_MS=5000
# NOMINATIM_MIN_INTERVAL_MS=1100
# Public Nominatim is low-volume/single-machine only; set NOMINATIM_BASE_URL to a
# self-hosted instance for higher traffic without an application release.
# Optional: override cerberus FTP host
CERBERUS_FTP_HOST=url.retail.publishedprices.co.il
# Admin bootstrap key name for create-key script
API_KEY_NAME=local-dev
# Master key (role=master). Put the real value only in local .env — never commit it.
# Create with: pnpm create-key -- --name=master-local --role=master
# SUPER_MCP_MASTER_API_KEY=smcp_replace_me
# Query-string credentials are disabled. Set to 1 only for legacy MCP clients
# that cannot send Authorization headers; this never enables query auth on REST.
# SUPER_MCP_ALLOW_MCP_QUERY_API_KEY=0

# Semantic index (pgvector + ontology)
# SUPER_MCP_EMBED_MODEL=Xenova/paraphrase-multilingual-MiniLM-L12-v2
# During cutover you can keep reading the previous generation:
# SUPER_MCP_EMBED_MODEL=local-char-ngram-v1
# SUPER_MCP_ONTOLOGY_VERSION=he-retail-v1
# SUPER_MCP_EMBED_BACKEND=hasher   # tests/CI; default is transformers
# SUPER_MCP_SKIP_SEMANTIC_DRAIN=1  # skip blocking post-ingest drain
# SUPER_MCP_SEMANTIC_BASKET=0      # disable hybrid resolution
# SUPER_MCP_SEMANTIC_SHADOW=1      # log lexical vs semantic disagreements
