{
  "name": "@super-mcp/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "dev": "tsx watch --tsconfig tsconfig.dev.json src/index.ts",
    "start": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "create-key": "tsx src/create-key.ts",
    "canary:basket": "tsx src/scripts/canaryBasket.ts",
    "canary:geocode": "tsx src/scripts/canaryGeocode.ts",
    "canary:mcp-contract": "tsx src/scripts/canaryMcpContract.ts",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@fastify/cors": "^11.0.1",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "@super-mcp/db": "workspace:*",
    "@super-mcp/shared": "workspace:*",
    "dotenv": "^16.5.0",
    "fastify": "^5.3.3",
    "zod": "^3.25.28"
  }
}
